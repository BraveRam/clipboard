{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipboard",
  "version": "0.1.0",
  "identifier": "com.plxor.clipboard",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Clipboard",
        "width": 620,
        "height": 460,
        "minWidth": 620,
        "minHeight": 460,
        "maxWidth": 620,
        "maxHeight": 460,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "center": true,
        "visible": true,
        "focus": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
